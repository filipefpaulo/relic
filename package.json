{
  "name": "relic-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:templates": "bun run scripts/embed-templates.ts",
    "build:binary": "bun run build:templates && bun build packages/cli-node/src/bin.ts --compile --outfile dist/relic",
    "dev": "bun run packages/cli-node/src/bin.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@types/node": "^25.6.0"
  }
}
