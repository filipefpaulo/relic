{
  "name": "relic-cli",
  "version": "0.1.6",
  "description": "Spec-driven development with a shared artifact layer",
  "type": "module",
  "bin": {
    "relic": "./dist/relic.js"
  },
  "files": [
    "dist/relic.js"
  ],
  "devDependencies": {
    "@relic/core": "workspace:*",
    "commander": "^14.0.3"
  },
  "scripts": {
    "build:binary": "bun build src/bin.ts --compile --outfile dist/relic",
    "build:npm": "bun build src/bin.ts --target node --outfile dist/relic.js"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "keywords": ["spec-driven", "ai", "relic", "cli", "llm"],
  "repository": {
    "type": "git",
    "url": "https://github.com/filipefpaulo/relic"
  },
  "homepage": "https://github.com/filipefpaulo/relic#readme"
}
