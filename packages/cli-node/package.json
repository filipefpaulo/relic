{
  "name": "relic-cli",
  "version": "0.8.10",
  "description": "Spec-driven development with a shared artifact layer",
  "type": "module",
  "bin": {
    "relic": "./dist/relic.js"
  },
  "files": [
    "dist/relic.js",
    "README.md"
  ],
  "devDependencies": {
    "@relic/core": "workspace:*",
    "@relic/utility": "workspace:*",
    "commander": "^14.0.3"
  },
  "scripts": {
    "build:binary": "bun build src/bin.ts --compile --outfile dist/relic --define 'INSTALL_CHANNEL=\"npm\"'",
    "build:npm": "bun build src/bin.ts --target node --outfile dist/relic.js --define 'INSTALL_CHANNEL=\"npm\"'"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "keywords": [
    "spec-driven",
    "ai",
    "relic",
    "cli",
    "llm"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/filipefpaulo/relic.git"
  },
  "homepage": "https://github.com/filipefpaulo/relic#readme"
}
